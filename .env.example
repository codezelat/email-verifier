# ============================================================
# Email Verifier v2.0 Configuration
# ============================================================

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=false
WORKERS=4

# ---- Authentication (REQUIRED) ----
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_API_KEY=change-this-to-a-strong-random-secret

# ---- SMTP Verification ----
# MAIL FROM address during SMTP checks
# IMPORTANT: Use a real address on a domain with valid SPF/DKIM/DMARC
VERIFY_FROM_EMAIL=verify@yourdomain.com

# EHLO hostname (should resolve to your server's IP)
VERIFY_EHLO_HOSTNAME=verify.yourdomain.com

# ---- Database ----
# Leave empty for SQLite (zero setup)
# PostgreSQL: postgresql+asyncpg://user:password@localhost/emailverifier
DATABASE_URL=

# ---- Caching ----
DNS_CACHE_TTL=3600
SMTP_CACHE_TTL=86400

# ---- Rate Limiting (per IP) ----
RATE_LIMIT_VERIFY=30/minute
RATE_LIMIT_BULK=5/minute

# ---- SMTP Timeouts (seconds) ----
SMTP_CONNECT_TIMEOUT=15
SMTP_COMMAND_TIMEOUT=10
SMTP_OVERALL_TIMEOUT=30

# ---- SMTP Per-Domain Rate Limits (emails/minute) ----
SMTP_RATE_GMAIL=3
SMTP_RATE_OUTLOOK=5
SMTP_RATE_YAHOO=3
SMTP_RATE_DEFAULT=15

# ---- SMTP Connection Limits ----
SMTP_MAX_CONCURRENT=20
SMTP_MAX_PER_HOST=3

# ---- Bulk Limits ----
BULK_MAX_SIZE=50

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Logging ----
LOG_LEVEL=INFO
