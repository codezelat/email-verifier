# Server Configuration
# Shared secret key for API authentication between client and server
SECRET_API_KEY=your-secret-api-key-here

# Mailboxlayer API Configuration
# Get your API key from: https://mailboxlayer.com/
MAILBOXLAYER_API_KEY=your-mailboxlayer-api-key-here

# Client Configuration
# URL where the verification server is running
PRIVATE_API_URL=http://localhost:5001

# Optional: Request timeout in seconds (default: 60)
REQUEST_TIMEOUT=60

# Optional: Server port (default: 5001)
PORT=5001

# Optional: Flask debug mode (default: False)
FLASK_DEBUG=False
